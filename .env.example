# === LLM named profiles (preferred) ===
# Each profile = one full connection config. Switch at runtime with:
#   LLM_DEFAULT_PROFILE=claude uv run python scripts/...
#
# Code usage: create_llm_client(profile="claude") or just create_llm_client()
# to use the default.

# MiniMax
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_PROVIDER=minimax
MINIMAX_EXTRA_BODY={"context_window_size":200000,"effort":"high"}
# Optional: poll interval (seconds) when quota is exhausted (2056). Default 300.
# Smaller = faster resume after quota refill but more log noise.
# MINIMAX_QUOTA_POLL_SECONDS=300
# Optional: cap cumulative wait per call. Default 21600 (6h).
# MINIMAX_QUOTA_MAX_WAIT_SECONDS=21600

# Claude (Anthropic direct)
# CLAUDE_BASE_URL=https://api.anthropic.com
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_PROVIDER=claude

# DeepSeek
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-reasoner
# DEEPSEEK_PROVIDER=deepseek

# DashScope (阿里云百炼) — Qwen via Anthropic-compatible endpoint
# DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# DASHSCOPE_API_KEY=sk-sp-...
# DASHSCOPE_MODEL=qwen3-coder-plus
# DASHSCOPE_PROVIDER=qwen

# Which profile wins when create_llm_client() is called without args.
LLM_DEFAULT_PROFILE=minimax

# === Legacy unified LLM (fallback only) ===
# Kept for backward compat with older code; profile loader above is preferred.
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_API_KEY=your-llm-api-key
LLM_MODEL=MiniMax-M2.7-highspeed
LLM_PROVIDER=minimax

# === Clash Proxy (optional, for AkShare rate limit bypass) ===
# Only needed if eastmoney push2 API is rate-limiting you.
# Requires Clash Verge (or mihomo) running locally.
#
# Find your settings:
#   Socket: check your clash-verge config for external-controller-unix
#   Proxy:  usually http://127.0.0.1:7890 (mixed-port in clash config)
#   Group:  the proxy group name containing your nodes (check Clash dashboard)
#
CLASH_SOCKET=/var/tmp/verge/verge-mihomo.sock
CLASH_PROXY=http://127.0.0.1:7890
CLASH_GROUP=龙猫云 - TotoroCloud
